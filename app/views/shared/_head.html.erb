<title>Puntapie <%= Rails.env.development? ? ' - Dev' : '' %></title>

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

<%#= favicon_link_tag asset_path('favicon.png') %>

<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<!--
Esta locura lo puse para cargar solo los estilos de login.scss cuando se está en la página de inicio de sesión.

No termina de funcionar del todo. Al cerrar sesión sigue cargando application.
-->
<% if current_page?(new_user_session_path) || current_page?(new_user_registration_path) %>
  <%= stylesheet_link_tag "login", media: "all" %>
<% else %>
  <%= stylesheet_link_tag "application", media: "all" %>
<% end %>

<%= javascript_importmap_tags %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.12.1/font/bootstrap-icons.min.css">
