<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <h1 class="h3 mb-3 fw-normal text-center">
    Crear Cuenta
  </h1>

  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="form-floating">
    <%= f.text_field :first_name, autofocus: true, class: "form-control mb-2", placeholder: "Nombre" %>
    <%= f.label :first_name, "Nombre" %>
  </div>

  <div class="form-floating">
    <%= f.email_field :email, class: "form-control mb-2", placeholder: "Email" %>
    <%= f.label :email, "Email" %>
  </div>

  <div class="form-floating">
    <%= f.password_field :password, autocomplete: "off", class: "form-control mb-2", placeholder: "Contraseña" %>
    <%= f.label :password, "Contraseña" %>
  </div>

  <div class="form-floating">
    <%= f.password_field :password_confirmation, autocomplete: "off", class: "form-control mb-3", placeholder: "Confirmar Contraseña" %>
    <%= f.label :password_confirmation, "Confirmar Contraseña" %>
  </div>

  <div class="form-group">
    <%= f.submit "Registrarme", class: "btn btn-primary w-100 py-2" %>
  </div>
<% end %>

<div class="text-center">
  <%= render "devise/shared/links" %>
</div>
